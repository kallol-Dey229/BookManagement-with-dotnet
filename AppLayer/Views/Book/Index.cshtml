@model List<BLL.DTOs.BookDTO>

<h2 class="mb-4">Book List</h2>
<form method="get"
      asp-action="Index"
      class="mb-4">

    <div class="d-flex">

        <input type="text"
               name="search"
               class="form-control me-2"
               placeholder="Search Book..." />

        <button type="submit"
                class="btn btn-primary">
            Search
        </button>

    </div>

</form>

<div class="row">

    @foreach (var b in Model)
    {
        <div class="col-md-4 mb-4">

            <div class="card shadow">

                <img src="@b.Image"
                     class="card-img-top mt-3"
                     style="height:250px; object-fit:contain;;" />

                <div class="card-body">

                    <h5 class="card-title">
                        @b.Title
                    </h5>

                    <p class="card-text">
                        <strong>Price:</strong> @b.Price Tk
                    </p>

                    <p class="card-text">
                        <strong>Category:</strong> @b.Cid
                    </p>

                    @if (Context.Session.GetString("Role") == "User")
                    {
                        <div class="d-flex justify-content-end">
                            <a class="btn btn-info">
                                Add To Cart
                            </a>
                        </div>
                    }

                </div>

                

                

                <div class="card-footer">
                    @if (Context.Session.GetString("Role") == "Admin")
                    {
                        <a asp-action="Edit"
                        asp-route-id="@b.Id"
                        class="btn btn-outline-secondary">
                            Edit
                        </a>

                        <a asp-action="Delete"
                        asp-route-id="@b.Id"
                        class="btn btn-danger">
                            Delete
                        </a>
                    }
                </div>

            </div>

        </div>
    }

</div>

@if (Context.Session.GetString("Role") == "Admin")
{
    <a asp-action="Create"
    class="btn btn-success">
        Add Book
    </a>
}
<a asp-controller="Category"
   asp-action="Index"
   class="btn btn-dark">
    Back to Category List
</a>
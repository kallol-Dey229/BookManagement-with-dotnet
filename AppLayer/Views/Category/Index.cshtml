@model List<BLL.DTOs.CategoryDTO>

<h2>Category List</h2>

<table class="table table-bordered">

    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>

            <td>
                <a class="btn btn-outline-secondary"
                   asp-action="Edit"
                   asp-route-id="@item.Id">
                    Edit
                </a>

                <a class="btn btn-danger"
                   asp-action="Delete"
                   asp-route-id="@item.Id">
                    Delete
                </a>
            </td>
        </tr>
    }

</table>

<div>
    <a class="btn btn-primary"
   asp-action="Create">
    Add Category
</a>
<a asp-controller="Book"
   asp-action="Index"
   class="btn btn-primary">
    See Book List
</a>
</div>
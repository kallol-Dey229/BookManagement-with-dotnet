<!DOCTYPE html>
<html>

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"]</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>

        .custom-navbar {
            background-color: #E5E7EB;
            padding: 15px;
            box-shadow: 0px 2px 8px rgba(0,0,0,.08);
        }

        .navbar-brand {
            font-size: 28px;
            font-weight: bold;
            color: #374151 !important;
        }

        .nav-link {
            margin-left: 15px;
            font-size: 18px;
            color: #374151 !important;
            font-weight: 500;
            padding: 8px 14px !important;
            border-radius: 0;
            transition: .2s;
        }

            .nav-link:hover {
                color: #111827 !important;
            }

        .active-link {
            border-bottom: 3px solid #60A5FA;
        }

    </style>

</head>

<body>

    <nav class="navbar navbar-expand-lg custom-navbar">

        <div class="container">

            @if (Context.Session.GetString("Role") != "Admin" && Context.Session.GetString("Role") != "User")
             {

            <a class="navbar-brand"
               asp-controller="Home"
               asp-action="Index">

                BookStore

            </a>

             }

            @if (Context.Session.GetString("Role") == "Admin")
             {
            <a class="navbar-brand"
               asp-controller="Dashboard"
               asp-action="AdminDashboard">

                BookStore

            </a>
               }


            @if (Context.Session.GetString("Role") == "User")
            {
                <a class="navbar-brand"
                   asp-controller="Dashboard"
                   asp-action="UserDashboard">

                    BookStore

                </a>
            }


           

            <div class="mx-auto">

                <ul class="navbar-nav flex-row align-items-center">

                    @if (Context.Session.GetString("Role") == "Admin")
                    {
                        <li class="nav-item">

                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active-link" : "")"
                               asp-controller="Category"
                               asp-action="Index">

                                Categories

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Book" ? "active-link" : "")"
                               asp-controller="Book"
                               asp-action="Index">

                                Books

                            </a>

                        </li>
                    }

                    else if (Context.Session.GetString("Role") == "User")
                    {
                        <li class="nav-item">

                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active-link" : "")"
                               asp-controller="Category"
                               asp-action="Index">

                                Categories

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Book" ? "active-link" : "")"
                               asp-controller="Book"
                               asp-action="Index">

                                Books

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link">

                                About Us

                            </a>

                        </li>
                    }

                </ul>

            </div>


            

            <div>

                @if (Context.Session.GetString("Role") != null)
                {
                    <a class="btn btn-outline-danger"
                       asp-controller="User"
                       asp-action="Logout">

                        Logout

                    </a>
                }

            </div>

        </div>

    </nav>


    <div class="container mt-4">

        @RenderBody()

    </div>


    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js">

    </script>

</body>

</html>